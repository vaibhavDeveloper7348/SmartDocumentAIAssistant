# Smart Document AI Assistant - Environment Configuration

# === Embedding Model ===
# Free sentence-transformers model for generating embeddings
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# === LLM Configuration ===
# Choose ONE LLM provider:

# Option 1: OpenAI (requires API key)
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_MODEL_NAME=gpt-3.5-turbo

# Option 2: Ollama (local, free)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL_NAME=llama2

# Option 3: Default - Uses HuggingFace pipeline (free, no API key)
# No configuration needed - uses the default local model

# === ChromaDB ===
# Directory to persist ChromaDB data
CHROMA_PERSIST_DIR=./chroma_db

# === Document Settings ===
# Default chunk size for splitting documents
CHUNK_SIZE=1000
# Overlap between consecutive chunks
CHUNK_OVERLAP=200

# === Server Settings ===
# FastAPI server configuration
HOST=0.0.0.0
PORT=8000
